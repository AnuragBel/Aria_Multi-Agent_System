# Required: Groq API key for LLM access
# Get one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Required: Tavily Search API key for web search
# Get one at https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Optional: HuggingFace token for HF models
HF_TOKEN=your_hf_token_here

# Optional: Serper API key (not used currently, code uses Tavily)
SERPER_API_KEY=your_serper_api_key_here
